- active_part = current_user.bootcamp_data.active_part
- alternate_part = active_part == 1 ? 2 : 1

#page-bootcamp-dashboard
  .lg-container
    .flex.mb-40
      .lhs.mr-48{ class: 'w-full max-w-[780px]' }
        %h1= t('.welcome_to_level', level_idx: @level.idx)
        .level-content
          = raw @level.content_html
          = link_to t('.go_to_level', level_idx: @level.idx), bootcamp_level_path(@level), class: "btn-l btn-primary mt-20 max-w-[200px]"

        %hr.border-borderColor5.my-20

        - if @exercise
          - if @solution
            %h2.mb-4= t('.continue_where_you_left_off')
            .text-18.mb-20= t('.exercise_in_progress')

            = render ViewComponents::Bootcamp::ExerciseWidget.new(@exercise, solution: @solution, size: "large")
          - else
            %h2.mb-4= t('.start_new_exercise')
            .text-18.mb-20= t('.new_exercise_available')
            = render ViewComponents::Bootcamp::ExerciseWidget.new(@exercise, size: "large")
        - else
          %h2.mb-8= t('.all_exercises_completed')
          .text-18.mb-20= t('.all_exercises_completed_description')

      .rhs.ml-auto{ class: 'max-w-[400px]' }
        %h2.mb-4= t('.upcoming_live_sessions')
        %ul.text-16.leading-140.list-disc.ml-16.mb-20.gap-4
          %li.mb-4
            %strong= t('.responsive_web_design')
            = link_to t('.responsive_web_design_time'), "https://youtube.com/live/FPWlkB2uL28?feature=share", class: 'text-linkColor font-semibold underline'
          %li.mb-4
            %strong= t('.final_live_session')
            = t('.final_live_session_time')

        %h2.mb-2= t('.make_the_most')
        %p.mb-16= t('.make_the_most_description')
        .flex.flex-col.gap-16
          = link_to bootcamp_level_path(@level), class: "section-link" do
            .level-number= @level.idx
            .text
              %h4= t('.level', level_idx: @level.idx)
              %p= @level.description

          = link_to "https://exercism.org/r/discord", class: "section-link" do
            = graphical_icon 'external-site-discord-blue'
            .text
              %h4= t('.chat_on_discord')
              %p= t('.chat_on_discord_description')

          = link_to "https://forum.exercism.org/c/bootcamp/661", class: "section-link" do
            = graphical_icon 'discourser'
            .text
              %h4= t('.ask_questions_on_forum')
              %p= t('.ask_questions_on_forum_description')

        - if current_user.bootcamp_data.enrolled_in_both_parts?
          .mt-32
            %h2.mb-2= t('.switch_to_part', part: alternate_part)
            %p.mb-8= t('.both_parts_access', active_part: active_part)
            %p.mb-8= t('.switch_anytime')
            %p.mb-8
              = button_to t('.switch_to_part', part: alternate_part), bootcamp_change_part_path(part: alternate_part), method: :post, class: "btn-m btn-primary"

        .mt-32
          = render ReactComponents::Settings::BootcampAffiliateCouponForm.new("bootcamp")
