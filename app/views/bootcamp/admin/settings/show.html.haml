#page-admin-settings.page-admin.pt-20
  .lg-container
    %h1= t('.title')

    %h2= t('.current_level')
    %p.mb-6.text-16= t('.level', level_idx: Bootcamp::Settings.instance.level_idx)

    = form_with url: increment_level_admin_settings_path, method: :post, local: true, id: "admin-settings-increment-level-form" do
      = button_tag t('.increment_level'), class: "btn btn-m btn-primary", data: { confirm: t('.confirm') }

:javascript
  document.addEventListener("DOMContentLoaded", function() {
    const form = document.getElementById("admin-settings-increment-level-form");
    form.addEventListener("submit", function(event) {
      const confirmed = confirm("Are you sure you want to increment the level?");
      if (!confirmed) {
        event.preventDefault();
      }
    });
  });
