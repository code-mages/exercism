#challenge-12in23-page
  %section.top-section
    .lg-container
      .flex
        .mr-auto{ class: 'max-w-[860px]' }
          .font-semibold.leading-150.flex.items-center.mb-4{ style: 'color: var(--colorPurpleToBrightPurple)' }
            %span.emoji.mr-6 📆
            = t('.month_label')
          %h1.text-h1.mb-8= t('.title')
          %p.text-p-xlarge.mb-20
            = t('.intro')

          .shadow-baseZ1.grid.grid-cols-2.gap-20.py-20.px-20.rounded-8.bg-backgroundColorB
            .flex-shrink
              %h2.text-h4.mb-2= t('.video_heading')
              %p.text-p-base.mb-8
                = t('.video_description')
              %p.text-p-base
                = t('.video_cta')

            .rhs
              %div{ class: 'w-[100%] max-w-[500px]' }
                = render ReactComponents::Common::YoutubePlayer.new('_w5Q3Tc1kqY', 'challenge#show')

          - tracks = Track.where(slug: User::Challenges::FeaturedExercisesProgress12In23::DECEMBER_TRACKS)
          %h2.text-h3.mt-32.mb-2= t('.learn_earn_heading')
          %p.text-p-large.mb-20
            = t('.learn_earn_description')
            - if tracks.any?(&:course?)
              = t('.syllabus_prefix')
              = graphical_icon "concepts", css_class: 'w-[14px] h-[14px] filter-purple inline mx-[-4px]'
              = t('.syllabus_suffix')

          .grid.grid-cols-6.gap-12.mb-32
            - tracks.each do |track|
              = link_to track, class: 'rounded-12 shadow-base hover:shadow-baseZ1 bg-backgroundColorA flex flex-col p-12 text-center relative' do
                - if track.course?
                  .rounded-circle.bg-backgroundColorA.p-4.shadow-baseZ1{ class: 'absolute top-[-7px] right-[-7px]' }
                    = graphical_icon "concepts", css_class: 'w-[14px] h-[14px] filter-purple'
                = image_tag track.icon_url, class: 'mb-8'
                .text-h6= track.title

          %p.text-p-large.mb-12
            = t('.recommended_intro')
          %ul.text-p-large.mb-12

            %li.mb-2
              = image_tag "#{Exercism.config.website_icons_host}/exercises/all-your-base.svg", class: "w-[25px] inline"
              %strong.font-semibold= t('.exercise_all_your_base_title')
              = t('.exercise_all_your_base_desc')
            %li.mb-2
              = image_tag "#{Exercism.config.website_icons_host}/exercises/flatten-array.svg", class: "w-[25px] inline"
              %strong.font-semibold= t('.exercise_flatten_array_title')
              = t('.exercise_flatten_array_desc')
            %li.mb-2
              = image_tag "#{Exercism.config.website_icons_host}/exercises/queen-attack.svg", class: "w-[25px] inline"
              %strong.font-semibold= t('.exercise_queen_attack_title')
              = t('.exercise_queen_attack_desc')
            %li.mb-2
              = image_tag "#{Exercism.config.website_icons_host}/exercises/dnd-character.svg", class: "w-[25px] inline"
              %strong.font-semibold= t('.exercise_dnd_character_title')
              = t('.exercise_dnd_character_desc')
            %li.mb-2
              = image_tag "#{Exercism.config.website_icons_host}/exercises/run-length-encoding.svg", class: "w-[25px] inline"
              %strong.font-semibold= t('.exercise_run_length_encoding_title')
              = t('.exercise_run_length_encoding_desc')

          %h2.text-h3.mt-32.mb-4= t('.learn_from_others_heading')
          %p.text-p-large.mb-12.c-highlight-links
            = t('.learn_from_others_intro')
            = t('.subscribe_prefix')
            = link_to t('.twitch_channel'), 'https://twitch.tv/exercismlive', class: 'underline'
            = t('.and')
            = link_to t('.youtube_channel'), 'https://www.youtube.com/exercism_videos?sub_confirmation=1', class: 'underline'
            = t('.subscribe_suffix')
            = t('.schedule_note')

          %h2.text-h3.mt-32.mb-4= t('.join_conversation_heading')
          %ul.text-p-large.list-disc.pl-16.c-highlight-links
            %li.mb-4
              = t('.conversation_prefix')
              #{link_to t('.forum_tag'), 'https://forum.exercism.org/tag/12in23'},
              #{t('.conversation_discord_prefix')} #{link_to t('.discord_server'), 'https://exercism.org/r/discord'},
              = t('.conversation_hashtag_prefix')
              %strong.font-semibold #12in23
              = t('.conversation_hashtag_suffix')

        .ml-80{ class: 'max-w-[450px]' }
          .bg-backgroundColorD.rounded-8.py-16.px-24.mb-24.border-1.border-borderColor7
            %h2.text-h4.mb-4= t('.streaming_schedule_heading')
            %p.text-p-base.mb-12.c-highlight-links
              = t('.streaming_schedule_intro')
              = link_to t('.twitch_channel'), 'https://twitch.tv/exercismlive', class: 'underline'
              = t('.streaming_schedule_subscribe')
              %strong.font-semibold= t('.times_utc')

            %ul.text-p-base.list-disc.pl-16
              - StreamingEvent.next_5.each do |event|
                %li.mb-4
                  .font-medium.text-textColor6.text-14.leading-100
                    = format_datetime(event.starts_at)
                  %strong.font-semibold.text-textColor2= event.title


          .bg-backgroundColorD.rounded-8.py-16.px-24.mb-24.border-1.border-borderColor7
            %h2.text-h4.mb-4= t('.how_it_works_heading')
            %p.text-p-base.mb-12
              = t('.how_it_works_description')
            .grid.grid-cols-2.gap-12
              = link_to "https://youtu.be/e15lRHLJQKI", class: 'bg-backgroundColorB p-8 shadow-smZ1 rounded-5 relative' do
                = graphical_icon "video-play", css_class: '!absolute top-[40px] w-[30px] left-[50%] ml-[-15px]', style: "filter: var(--white-filter) drop-shadow(0px 0px 6px black)"
                = image_tag "https://assets.exercism.org/images/thumbnails/yt-12in23-feb-update.jpg", alt: t('.video_thumbnail_alt'), class: 'mb-8 block block w-fill rounded-5'
                .text-center.text-h6= t('.video_hows_it_going')

              = link_to "https://youtu.be/2refhxXqePI", class: 'bg-backgroundColorB p-8 shadow-smZ1 rounded-5 relative' do
                = graphical_icon "video-play", css_class: '!absolute top-[40px] w-[30px] left-[50%] ml-[-15px]', style: "filter: var(--white-filter) drop-shadow(0px 0px 6px black)"
                = image_tag "https://assets.exercism.org/images/thumbnails/yt-official-12in23-calendar.jpg", alt: t('.video_thumbnail_alt'), class: 'mb-8 block w-fill rounded-5'
                .text-center.text-h6= t('.video_official_calendar')

            %p.text-p-small.text-center.mt-20.bg-backgroundColorA.rounded-8.py-8.px-12.font-medium
              = t('.track_progress_note')

          .bg-backgroundColorD.rounded-8.py-16.px-24.border-1.border-borderColor7
            %h2.text-h4.mb-4= t('.donate_heading')
            %p.text-p-base.mb-12
              = t('.donate_description')
            = link_to t('.donate_now'), donate_path, class: 'btn btn-primary'

          .bg-backgroundColorD.rounded-8.py-16.px-24.border-1.border-borderColor7.mt-24
            %h2.text-h4.mb-4= t('.year_badge_heading')
            %p.text-p-base.mb-12
              = t('.year_badge_description')

              = t('.year_badge_hover_prefix')
              = link_to t('.this_forum_post'), 'https://forum.exercism.org/t/new-12in23-badge-for-completing-all-the-things/4183', class: 'font-semibold text-linkColor'
              = t('.year_badge_hover_suffix')

            - if @badge_progress_exercises.present?
              %h2.text-h6.mt-20.mb-12
                = t('.published_exercises')
                .inline.text-14= t('.badge_progress_count', earned: @badge_progress_exercise_earned_count, total: @badge_progress_exercise_count)
              .grid.grid-cols-5.gap-12
                - @badge_progress_exercises.each do |exercise_progress|
                  - if exercise_progress[:earned_for].present?
                    = link_to track_exercise_path(exercise_progress[:earned_for], exercise_progress[:slug]), class: "relative block" do
                      = image_tag "#{Exercism.config.website_icons_host}/exercises/#{exercise_progress[:slug]}.svg", class: "w-100", title: t('.solved_in', track: exercise_progress[:earned_for])
                      = icon "completed-check-circle", t('.completed'), css_class: "w-[16px] !absolute right-[2px] top-[2px]"
                  - else
                    = image_tag "#{Exercism.config.website_icons_host}/exercises/#{exercise_progress[:slug]}.svg", class: "w-100 opacity-[0.7] grayscale", title: t('.solve_in', slug: exercise_progress[:slug], tracks: exercise_progress[:track_slugs].to_sentence(last_word_connector: ', or ', two_words_connector: ', or '))
            - else
              %h2.text-h6.mt-20= t('.no_solutions')

  %article
    .md-container
      .flex.text-center.flex-col.items-center
        %h1.text-h1.mb-16= t('.progress_heading')
        %p.text-p-xlarge
          = t('.progress_intro')
        %p.text-p-large.cta
          = t('.progress_cta')

      .grid.grid-cols-4.gap-32.mx-auto
        - @track_counts.each do |track_id, count|
          - track = @tracks[track_id]
          = link_to track_path(track), class: "relative text-center shadow-baseZ1 bg-backgroundColorA py-16 px-24 rounded-8 flex flex-col items-center border-2 #{count >= 5 ? 'border-successColor' : 'border-transparent'}" do
            = image_tag track.icon_url, alt: '', class: "c-icon c-track-icon h-[48px] w-[48px] mb-8"
            .text-h4.mb-20= track.title
            - if count >= 5
              = icon "completed-check-circle", t('.completed'), width: 24, height: 24, css_class: "!absolute top-[-12px] right-[-12px]"
              .progress
              .count= t('.exercises_completed', count: count)
            - else
              %progress.progress-bar{ value: count, max: 5 }
              .count= t('.exercises_completed_of', count: count)

        - num_placeholders = 12 - @track_counts.size
        - if num_placeholders.positive?
          - num_placeholders.times do
            .shadow-base.bg-backgroundColorA.rounded-8.flex.flex-col.items-center.justify-center.opacity-60{ class: 'min-h-[175px]' }
              .text-h0{ class: "opacity-[0.2]" } ?
