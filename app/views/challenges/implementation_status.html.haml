:css
  th, td {
    border: 1px solid var(--borderColor8);
    text-align:center;
    padding:8px;
    line-height:130%;
  }
  td {
    white-space:nowrap;
  }
  #site-footer { display: none !important }
  body {
    width: 4000px;
  }


.p-32
  .text-h3.mb-8= t('.heading')
  .text-h5.mb-4= t('.key_to_symbols')
  .text-16
    .mb-8= t('.legend_featured')
    .mb-8= t('.legend_present')
    .mb-8= t('.legend_missing_html', link: link_to(t('.please_add_it'), doc_path(:building, 'tracks/practice-exercises'), class: 'font-semibold text-linkColor'))
    .mb-16= t('.legend_do_not_implement')

    = t('.want_to_implement')
    = t('.start_with_html', link: link_to(t('.this_video_and_docs'), doc_path(:building, 'tracks/practice-exercises'), class: 'font-semibold text-linkColor'))
  %hr.mt-20.mb-32.border-borderColor5

  .flex.items-start{ class: "max-h-[90vh]" }
    %table.sticky{ class: "left-[0px] z-[2]" }
      %tr
        %th.bg-backgroundColorB{ class: 'h-[100px]' }
        - @tracks.each do |track|
          %tr
            %td.p-8.font-semibold.bg-backgroundColorD
              = link_to track.title, track_implementation_status_challenge_path('48in24', track.slug)

    %div
      %table
        %thead.sticky{ class: "top-[0px]" }
          %tr
            - @featured_exercises.each.with_index do |featured_exercises, idx|
              %th.bg-backgroundColorD.align-top{ class: 'h-[100px]' }
                .text-textColor7.mb-4 W#{idx + 1}
                = link_to featured_exercises[:slug], approaches_generic_exercise_path(featured_exercises[:slug])
        %tbody
          - @tracks.each do |track|
            %tr
              - @featured_exercises.each do |featured_exercise|
                %td.p-8
                  - case @track_exercises_status[track.slug][featured_exercise[:slug]]
                  - when :do_not_implement
                    ⛔
                  - when :featured
                    = link_to "💜", track_exercise_url(track, featured_exercise[:slug])
                  - when :present
                    = link_to "✅", track_exercise_url(track, featured_exercise[:slug])
                  - else
                    ❌
