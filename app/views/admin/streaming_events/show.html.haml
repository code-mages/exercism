.lg-container
  %h1.text-h1= @streaming_event.title

  .text-h6.mb-8= t('.title_label', value: @streaming_event.title)
  .text-h6.mb-8= t('.description_label', value: @streaming_event.description)
  .text-h6.mb-8= t('.starts_at_label', value: format_date(@streaming_event.starts_at))
  .text-h6.mb-8= t('.ends_at_label', value: format_date(@streaming_event.ends_at))
  .text-h6.mb-8= t('.featured_label', value: (@streaming_event.featured? ? t('.featured_yes') : t('.featured_no')))
  .text-h6.mb-8= t('.thumbnail_label', value: @streaming_event.thumbnail_url)
  .text-h6.mb-8= t('.youtube_id_label', value: @streaming_event.youtube_id)

  .flex
    = link_to t('.edit'), edit_admin_streaming_event_path(@streaming_event), class: 'btn btn-standard btn-base'
    |
    = button_to t('.destroy'), [:admin, @streaming_event], method: :delete, data: { confirm: t('.confirm', title: @streaming_event.title) }, class: 'btn btn-warning'
    |
    = link_to t('.back'), admin_streaming_events_path, class: 'btn btn-standard btn-base'
