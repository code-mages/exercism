.c-admin-table
  .lg-container
    %h1.text-h1.mb-8= t('.title')

    = form_with url: search_admin_users_path, method: :get do |form|
      .flex.flex-col
        .mb-12
          = form.label :email, class: "block mb-4"
          = form.email_field :email, class: 'w-fill'
        .mb-12
          = form.submit t('.search'), class: "btn btn-primary"

    - if @user
      .text-h6.mb-8= t('.name_label', value: @user.name)
      .text-h6.mb-8= t('.handle_label', value: @user.handle)
      .text-h6.mb-8= t('.email_label', value: @user.email)
      .text-h6.mb-8= t('.reputation_label', value: @user.reputation)
      .text-h6.mb-8= t('.joined_at_label', value: @user.created_at)
      .text-h6.mb-8= t('.last_visited_label', value: @user.last_visited_on)
      .text-h6.mb-8= t('.total_donated_label', value: @user.total_donated_in_cents)
      - if @user.disabled?
        .text-h6.mb-8.text-danger= t('.disabled_at_label', value: @user.disabled_at)
    - elsif @searched
      .mb-12.text-p-base.font-bold.text-danger= t('.not_found')
