.c-admin-table
  .lg-container
    %h1.text-h1.mb-8= t('.donors')
    - if flash[:donors_notice]
      .mb-12.text-p-base.font-bold.text-darkSuccessGreen= flash[:donors_notice]

    %table.mb-8
      %tr
        %th= t('.name')
        %th= t('.handle')
        %th= t('.email')
        %th= t('.total_donated_in_cents')
        %th= t('.became_donor_at')
      - @donors.each do |donor|
        %tr
          %td= donor.name
          %td= donor.handle
          %td= donor.email
          %td= donor.total_donated_in_cents
          %td= format_datetime(donor.first_donated_at)
    .flex
      = link_to t('.new_donor'), new_admin_donor_path, class: 'btn btn-primary btn-base'

    = paginate @donors
