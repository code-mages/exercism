.c-admin-page
  .lg-container
    %h1.text-h1.mb-8= t('.partners')
    %table.mb-20.c-admin-table
      %tr
        %th= t('.partner')
        %th{ colspan: 2 }
      - @partners.each do |partner|
        %tr
          %td= partner.name
          %td.w-arbitary= link_to t('.details'), [:admin, partner]
          %td.w-arbitary= link_to t('.edit'), edit_admin_partner_path(partner)
    .flex
      = link_to t('.add_new_partner'), new_admin_partner_path, class: 'btn btn-primary btn-base'
