%section#bootcamp
  .lg-container
    .container.syllabus
      .tag= t('.works.how_it_works')
      %h2
        %strong Exercism
        = t('.works.bootcamp')
      %p.intro.mb-24.text-balance
        = t('.works.split_two_halves')

      .sections
        .section.mb-32
          .lhs
            %h3.mb-8
              = t('.works.part1_title')
              .bubble= t('.works.part1_bubble')

            .part-intro.mb-20
              = t('.works.part1_intro_start')
              %span.rough-highlight.font-medium= t('.works.part1_foundations')
              = t('.works.part1_intro_end')

            %ul
              %li
                = image_tag "bootcamp/understanding.svg"
                .text
                  %strong= t('.works.solid_understanding_lead')
                  = t('.works.solid_understanding')
              %li
                = image_tag "bootcamp/confidence.svg"
                .text
                  %strong= t('.works.confidence_lead')
                  = t('.works.confidence')
              %li
                = image_tag "bootcamp/coders-mind.svg"
                .text
                  %strong= t('.works.coders_mind_lead')
                  = t('.works.coders_mind')
          .rhs
            .dates.h3-sideheading.relative
              = image_tag "bootcamp/calendar.svg"
              = t('.works.part1_dates')
            = image_tag "bootcamp/part-1.png", class: 'w-[350px] -mr-32 -mt-[60px]'

        .section.relative
          #part-2-arrow.arrow-animation
          .lhs
            %h3.mb-8
              = t('.works.part2_title')
              .bubble= t('.works.part2_bubble')
            .part-intro
              = t('.works.part2_intro_start')
              %span.rough-highlight.font-medium= t('.works.part2_frontend')
              = t('.works.part2_intro_end')

            %ul
              %li
                = image_tag "bootcamp/javascript.svg"
                .text
                  %strong= t('.works.javascript_lead')
                  = t('.works.javascript')

              %li
                = image_tag "bootcamp/html.svg"
                .text
                  %strong= t('.works.html_css_lead')
                  = t('.works.html_css')

              %li
                = image_tag "bootcamp/work-locally.svg"
                .text
                  %strong= t('.works.vscode_git_lead')
                  = t('.works.vscode_git')

              %li
                = image_tag "bootcamp/portfolio.svg"
                .text
                  %strong= t('.works.portfolio_lead')
                  = t('.works.portfolio')
          .rhs
            .dates.h3-sideheading.z-overlay
              = image_tag "bootcamp/calendar.svg"
              = t('.works.part2_dates')
            = image_tag "bootcamp/part-2.png", class: 'w-[350px] -mr-32 -mt-[60px]'

  .lg-container
    #schedule-subsection.subcontainer.relative
      #schedule-arrow.arrow-animation
      .flex.flex-col.mb-8{ class: 'lg:flex-row' }
        %h3.mr-auto
          = t('.schedule.your_week')
        .h3-sideheading.flex.mt-8.flex-wrap
          .flex.items-center.gap-8
            = image_tag "bootcamp/teacher.svg"
            .mr-20.whitespace-nowrap= t('.schedule.hours_teaching')
          .flex.items-center.gap-8
            = image_tag "bootcamp/study.svg"
            .mr-20.whitespace-nowrap= t('.schedule.hours_project_work')
      %p.mb-12
        = t('.schedule.mix_of_sessions')

      %ul
        %li
          = image_tag "bootcamp/teacher-illustration.svg"
          %h4= t('.schedule.teaching_sessions_title')
          %p= t('.schedule.teaching_sessions_body')
        %li
          = image_tag "bootcamp/coding-illustration.svg"
          .text
            %h4= t('.schedule.fun_coding_title')
            %p= t('.schedule.fun_coding_body')
        %li
          = image_tag "bootcamp/unstuck-illustration.svg"
          .text
            %h4= t('.schedule.get_help_title')
            %p= t('.schedule.get_help_body')
        %li
          = image_tag "bootcamp/discussion-illustration.svg", class: "scale-x-[-1]"
          .text
            %h4= t('.schedule.discussing_title')
            %p= t('.schedule.discussing_body')

  .lg-container
    #portfolio-subsection.subcontainer.relative
      #portfolio-arrow.arrow-animation
      .flex.flex-col.mb-8{ class: 'lg:flex-row' }
        %h3.mr-auto
          = t('.portfolio.things_well_build')
        .h3-sideheading
          = t('.portfolio.build_your_portfolio')
      %p.mb-16
        = t('.portfolio.focus_from_day_one')
      .projects
        .project.snake
          .img
          .title
            = t('.portfolio.snake_start')
            %strong= t('.portfolio.snake_name')
            = t('.portfolio.snake_end')
        .project.tetris
          .img
          .title
            = t('.portfolio.tetris_start')
            %strong= t('.portfolio.tetris_name')
            = t('.portfolio.tetris_end')
        .project.breakout
          .img
          .title
            = t('.portfolio.breakout_start')
            %strong= t('.portfolio.breakout_name')
        .project.tic-tac-toe
          .img
          .title
            = t('.portfolio.ttt_start')
            %strong= t('.portfolio.ttt_name')
        .project.weather
          .img
          .title
            = t('.portfolio.weather_start')
            %strong= t('.portfolio.weather_name')
        .project.story
          .img
          .title
            = t('.portfolio.story_start')
            %strong= t('.portfolio.story_name')
        .project.positive
          .img
          .title
            = t('.portfolio.positive_start')
            %strong= t('.portfolio.positive_name')
            = t('.portfolio.positive_end')
        .project.piano
          .img
          .title
            = t('.portfolio.piano_start')
            %strong= t('.portfolio.piano_name')
            = t('.portfolio.piano_end')

  .lg-container
    .subcontainer
      #certificate-arrow.arrow-animation
      #certificate-subsection
        .flex.lg:flex-row.flex-col.items-center.gap-0

          .lhs.flex.flex-col.items-start
            .bubble= t('.certificate.celebrate')
            %h3.mb-8= t('.certificate.get_verified')
            %p.text-16.mb-12= t('.certificate.at_the_end')
            %p.text-16= t('.certificate.show_off')

          = image_tag "bootcamp/certificate-arrow.png", class: 'w-[100px] self-middle mt-[100px] mb-10 mr-40 my-10 lg:block hidden'
          .certificate.flex-shrink-0.mt-24.lg:mt-0
            = image_tag "bootcamp/certificate.png", class: 'lg:w-[350px] w-100 rounded-[5px]', style: 'box-shadow: 0 0 20px rgba(0,0,0,0.4)'
        .linkedin
          = image_tag "bootcamp/linkedin.png"
          %span= t('.certificate.share_in_network')

%section#testimonial-section
  .lg-container
    .quote
      = image_tag "bootcamp/quote.png", class: 'mark left-mark'
      %span
        = t('.testimonial.quote')
        = image_tag "bootcamp/quote.png", class: 'mark right-mark'
    .person
      .text
        .name Loretta Bresciani Murray
        .description= t('.testimonial.role')
      = image_tag "bootcamp/loretta.png"

%section#signup-section
  .lhs-bg
  .rhs-bg
  .lg-container
    %h2.text-center.font-medium
      = t('.signup.choose_journey')
    %p.intro.text-balance
      = t('.signup.two_options')
    - if @has_discount
      #discount-bar
        .flag= flag_for_country_code(@country_code_2)
        - if @hello.present?
          %strong #{@hello}!
        = t('.signup.everyone_in', country: @country_name)
        %strong.inline= t('.signup.percent_discount', percentage: @discount_percentage)
    .grid.md:grid-cols-2.grid-cols-1.gap-40
      .container
        .header
          = image_tag "bootcamp/exercism-face-dark.svg", class: "face"
          .flex.flex-col.items-start
            .bubbles
              .bubble
                = t('.signup.only')
                %strong= t('.signup.part_1')

            %h2
              = t('.signup.learn_to')
              %strong= t('.signup.code')
            %p= t('.signup.part1_fundamentals')
          - if @has_discount
            .price
              %strong $#{@part_1_price}
              %span{ class: "text-[26px] line-through text-[#777] font-normal" } $#{@full_part_1_price}
            .discount

              = t('.signup.includes_a')
              %strong= t('.signup.percent_discount_plain', percentage: @discount_percentage)
              = t('.signup.for_friends_in')
              %span.flag= flag_for_country_code(@country_code_2)
              #{@country_name}!
          - else
            .price
              %strong $#{@full_part_1_price}
        .body
          .point
            %h4= t('.signup.whos_it_for')
            %p
              = t('.signup.part1_who_start')
              %strong= t('.signup.coding_fundamentals')
              = t('.signup.designed_for')
              %strong= t('.signup.absolute_beginners')
              = t('.signup.new_devs')

          .point
            %h4= t('.signup.duration')
            %p.mb-12= t('.signup.part1_duration')

          .point
            %h4= t('.signup.where_by_end')
            %p
              = t('.signup.part1_end_start')
              %strong= t('.signup.coding_fundamentals')
              = t('.signup.part1_end_mid')
              %strong= t('.signup.data_science')

          .point
            %h4= t('.signup.whats_included')
            %ul.list-disc
              %li= t('.signup.part1_included_1')
              %li= t('.signup.part1_included_2')
              %li= t('.signup.part1_included_3')
              %li= t('.signup.part1_included_4')
              %li= t('.signup.part1_included_5')

          = link_to t('.signup.enroll_now'), bootcamp_enroll_path(package: 'part_1'), class: "button"

      .container
        .header
          = image_tag "bootcamp/exercism-face-dark.svg", class: "face"

          .bubbles
            .bubble
              = t('.signup.the')
              %strong= t('.signup.complete_course')
          %h2
            = t('.signup.become_a')
            %strong= t('.signup.frontend_dev')
          %p= t('.signup.complete_expand')

          -# %p.mb-12{class: "!font-semibold"} One-time payment. Lifetime access. Money-back guarantee.
          - if @has_discount
            .price
              %strong $#{@complete_price}
              %span{ class: "text-[26px] line-through text-[#777] font-normal" } $#{@full_complete_price}
            .discount
              = t('.signup.includes_a')
              %strong= t('.signup.percent_discount_plain', percentage: @discount_percentage)
              = t('.signup.for_friends_in')
              %span.flag= flag_for_country_code(@country_code_2)
              #{@country_name}.
          - else
            .price
              %strong $#{@full_complete_price}
        .body
          .point
            %h4= t('.signup.whos_it_for')
            %p
              = t('.signup.complete_who_start')
              %strong= t('.signup.web_developer')
              = t('.signup.designed_for')
              %strong= t('.signup.absolute_beginners')
              = t('.signup.new_devs')

          .point
            %h4= t('.signup.duration')
            %p.mb-12= t('.signup.complete_duration')

          .point
            %h4= t('.signup.where_by_end')
            %p
              = t('.signup.complete_end_start')
              %strong= t('.signup.frontends_scratch')
              = t('.signup.complete_end_end')

          .point
            %h4= t('.signup.whats_included')
            %ul.list-disc
              %li= t('.signup.complete_included_1')
              %li= t('.signup.complete_included_2')
              %li= t('.signup.complete_included_3')
              %li= t('.signup.complete_included_4')
              %li= t('.signup.complete_included_5')

          = link_to t('.signup.enroll_now'), bootcamp_enroll_path(package: 'complete'), class: "button"

= image_tag "bootcamp/divider.png", class: 'w-[100px] mx-auto my-64'

