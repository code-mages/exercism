      %h4= t('.faqs.q_time')
      %p= t('.faqs.a_time')
    .faq
      %h4= t('.faqs.q_join_later')
      %p= t('.faqs.a_join_later')
    .faq
      %h4= t('.faqs.q_group')
      %p= t('.faqs.a_group')
    .faq
      %h4= t('.faqs.q_language')
      %p= t('.faqs.a_language')
