%section#faqs
  .background
  .md-container.relative
    %h2= t('.faqs.title')
    %p.intro
      = t('.faqs.intro')
      = link_to t('.faqs.ping_email'), "#"

    .faq
      %h4= t('.faqs.q_start')
      %p= t('.faqs.a_start')
