#countdown-bar
  %strong.inline-block= t('.countdown.late_enrollments')
  %span.inline-block
    = t('.countdown.watch_back')
    = succeed('.') do
      = link_to t('.countdown.first_live_session'), "https://www.youtube.com/live/bOAL_EIFwhg&start=1400", class: "underline font-semibold"

#nav
  .lg-container.flex.flex-row.gap-8.items-center
    = image_tag "bootcamp/exercism-face-light.svg", class: 'exercism-face'
    .content
      %strong.font-semibold Exercism
      = t('.nav.bootcamp')
    = link_to t('.nav.watch_first_session'), "https://www.youtube.com/live/bOAL_EIFwhg&start=1400", class: "first-session", target: "_blank", rel: 'noopener'
    = link_to t('.nav.enroll_now'), bootcamp_enroll_path, class: "button"

.hero
  .md-container
    .text-center
      %h1.rock-solid
        = t('.hero.build_rock_solid')
        %span= t('.hero.foundations')
      .tagline
        = t('.hero.tagline_start')
        %strong= t('.hero.coding_bootcamp')
        = t('.hero.tagline_end')
        = t('.hero.starts')
        %strong= t('.hero.start_date')

    .bubbles
      .bubble
        = image_tag "bootcamp/wave.svg"
        .text
          %strong= t('.hero.live')
          = t('.hero.teaching')
      .bubble
        = image_tag "bootcamp/fun.svg"
        .text
          %strong= t('.hero.fun')
          = t('.hero.projects')
      .bubble
        - if @has_discount
          .flag= flag_for_country_code(@country_code_2)
          .text
            %span.line-through{ class: 'text-[#666]' } $#{@full_complete_price}
            = t('.hero.only')
            %strong $#{@complete_price}
        - else
          = image_tag "bootcamp/cost.svg"
          .text
            = t('.hero.only')
            %strong $#{@full_complete_price}

    .video-container
      .video
        <iframe src="https://player.vimeo.com/video/1024390839?h=c2b3bdce14&amp;badge=0&amp;autopause=0&amp;player_id=0&amp;app_id=58479" frameborder="0" allow="autoplay; fullscreen; picture-in-picture; clipboard-write" style="position:absolute;top:0;left:0;width:100%;height:100%;" title="bootcamp"></iframe>
        <script src="https://player.vimeo.com/api/player.js"></script>

    .supported-by
      %h3= t('.hero.supporters_include')
      .logos
        = image_tag "bootcamp/google.png", class: 'h-[42px] mt-[3px]'
        = image_tag "bootcamp/chicago.svg", class: 'h-[38px]'
        = image_tag "bootcamp/mozilla.svg", class: 'h-[38px] mt-[-7px]'
        = image_tag "bootcamp/packt.svg", class: 'h-[38px] mt-[2px]'

  .paper-tear

