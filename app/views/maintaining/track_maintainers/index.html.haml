- require_stylesheet "maintaining"

:css
  #maintaining-track-maintainers {
    padding:25px 5%;
    font-size: 16px;
  }
  h2 {
    font-size: 20px;
    margin-bottom: 16px;
  }
  table {
    width: 100%;
    border-collapse: collapse;
  }
  th {
    border: 1px solid #ddd;
    border-bottom: 1px solid #888;
    padding: 10px;
    text-align:left;
    font-weight:600px;
  }
  td {
    border: 1px solid #ddd;
    border-bottom: 1px solid #aaa;
    padding: 10px;
    white-space: pre;
    font:monospace;
    vertical-align:top;
    white-space: pre-wrap;
  }

#maintaining-track-maintainers
  %h2.text-h3= t('.title')

  .text-h5.mb-4= t('.legend')
  .text-16
    .mb-8
      = t('.active_desc')
      %strong= t('.shows_exercism_login')
    .mb-8
      = t('.inactive_desc')
      %strong= t('.shows_exercism_login')
    .mb-8
      = t('.candidates_desc')
      %strong= t('.shows_exercism_login')
    .mb-8
      = t('.contributors_desc')
      %strong= t('.shows_exercism_login')
    .mb-16
      = t('.unlinked_desc')
      %strong= t('.shows_github_username')
  .text-h5.mb-4= t('.cutoff_values_used')
  .text-16
    .mb-8= t('.min_rep_member', value: Track::RetrieveMaintainersStatus::MIN_REP_FOR_MEMBER)
    .mb-8= t('.min_rep_candidate', value: Track::RetrieveMaintainersStatus::MIN_REP_FOR_CANDIDATE)
    .mb-8= t('.last_months_rep', value: Track::RetrieveMaintainersStatus::LAST_NUMBER_OF_MONTHS_FOR_REP)

  %table.mb-16.c-admin-table
    %thead
      %tr
        %th= t('.th_track')
        %th= t('.th_active')
        %th= t('.th_inactive')
        %th= t('.th_candidates')
        %th= t('.th_contributors')
        %th= t('.th_unlinked')

    %tbody
      - @track_maintainers_status.each do |track, maintainers|
        %tr
          %td= track.title
          %td
            %ul
            - maintainers[:active].each do |maintainer|
              %li
                #{maintainer[:handle]} (#{maintainer[:reputation]} rep)
                - if maintainer[:github_username]
                  (#{link_to t('.commits'), "#{track.repo_url}/commits?author=#{maintainer[:github_username]}"})
          %td
            %ul
            - maintainers[:inactive].each do |maintainer|
              %li
                #{maintainer[:handle]} (#{maintainer[:reputation]} rep)
                - if maintainer[:github_username]
                  (#{link_to t('.commits'), "#{track.repo_url}/commits?author=#{maintainer[:github_username]}"})
          %td
            %ul
            - maintainers[:candidates].each do |maintainer|
              %li
                #{maintainer[:handle]} (#{maintainer[:reputation]} rep)
                - if maintainer[:github_username]
                  (#{link_to t('.commits'), "#{track.repo_url}/commits?author=#{maintainer[:github_username]}"})
          %td
            %ul
            - maintainers[:contributors].each do |maintainer|
              %li
                #{maintainer[:handle]} (#{maintainer[:reputation]} rep)
                - if maintainer[:github_username]
                  (#{link_to t('.commits'), "#{track.repo_url}/commits?author=#{maintainer[:github_username]}"})
          %td
            %ul
            - maintainers[:unlinked].each do |maintainer|
              %li #{link_to maintainer[:github_username], "https://github.com/#{maintainer[:github_username]}"} (#{link_to t('.commits'), "#{track.repo_url}/commits?author=#{maintainer[:github_username]}"})

  %p.mb-16
    = button_to t('.clear_cache'), maintaining_track_maintainers_path, method: :post, form: { data: { turbo_confirm: t('.clear_cache_confirm') } }, class: 'btn btn-warning'
